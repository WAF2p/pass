# wafpass-core (pass) — optional environment variables for the CLI
# Copy to .env and source before running: `export $(grep -v '^#' .env | xargs)`
# None of these are required — wafpass-core works fully offline without them.

# ── Server push ───────────────────────────────────────────────────────────────
# Automatically POST scan results to wafpass-server after every run.
# Equivalent to always passing --push <url> to `wafpass check`.
# Must include the /runs endpoint path.
WAFPASS_SERVER_URL=http://localhost:8000/runs

# ── Export plugins ────────────────────────────────────────────────────────────
# Values referenced as ${VAR} in .wafpass-export.yml are expanded from the
# environment at load time and never stored in config files or result JSON.
# Uncomment and fill in the secrets required by your export destinations:

# GRAFANA_CLOUD_TOKEN=your-grafana-cloud-token
# DD_API_KEY=your-datadog-api-key
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# WEBHOOK_TOKEN=your-generic-webhook-secret
